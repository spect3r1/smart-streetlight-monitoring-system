APP_NAME=Street Light Backend
SECRET_KEY=replace-with-a-long-random-secret-at-least-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=1440
DATABASE_URL=sqlite:///./streetlight.db
CORS_ORIGINS=*

MQTT_HOST=127.0.0.1
MQTT_PORT=1883
MQTT_USERNAME=streetlight
MQTT_PASSWORD=replace-with-the-broker-password
MQTT_CLIENT_ID=streetlight-backend
MQTT_TELEMETRY_TOPIC=streetlight/+/telemetry
MQTT_STATUS_TOPIC=streetlight/+/status
MQTT_COMMAND_TOPIC_TEMPLATE=streetlight/{device_id}/command

DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=change-this-admin-password
